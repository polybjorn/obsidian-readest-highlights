{
  "name": "obsidian-readest-highlights",
  "version": "1.4.0",
  "description": "Import highlights and annotations from Readest into Obsidian.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "lint": "eslint .",
    "test": "tsx --test tests/*.test.ts"
  },
  "keywords": [
    "obsidian",
    "readest",
    "highlights",
    "annotations"
  ],
  "license": "MIT",
  "overrides": {
    "yaml": "^2.8.3",
    "flatted": "^3.4.0",
    "ajv@^6": "^6.14.0",
    "minimatch@^3": "^3.1.3",
    "brace-expansion@^1": "^1.1.13"
  },
  "devDependencies": {
    "@eslint/js": "9.30.1",
    "@types/node": "^26.1.1",
    "esbuild": "0.28.1",
    "eslint-plugin-obsidianmd": "0.1.9",
    "globals": "17.7.0",
    "jiti": "2.7.0",
    "obsidian": "1.13.1",
    "tslib": "2.8.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.63.0"
  }
}
