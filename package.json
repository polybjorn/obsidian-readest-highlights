{
  "name": "obsidian-readest-highlights",
  "version": "1.0.1",
  "description": "Import highlights and annotations from Readest into Obsidian.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "lint": "eslint .",
    "test": "tsx --test tests/*.test.ts"
  },
  "keywords": [
    "obsidian",
    "readest",
    "highlights",
    "annotations"
  ],
  "license": "MIT",
  "overrides": {
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "^25.8.0",
    "esbuild": "0.28.0",
    "eslint-plugin-obsidianmd": "0.3.0",
    "globals": "17.6.0",
    "jiti": "2.7.0",
    "obsidian": "1.12.3",
    "tslib": "2.8.1",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.59.3"
  }
}
