{
  "name": "obsidian-readest-highlights",
  "version": "1.0.0",
  "description": "Import highlights and annotations from Readest into Obsidian.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "lint": "eslint .",
    "test": "tsx --test tests/*.test.ts"
  },
  "keywords": [
    "obsidian",
    "readest",
    "highlights",
    "annotations"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "9.30.1",
    "@types/node": "^16.11.6",
    "esbuild": "0.25.5",
    "eslint-plugin-obsidianmd": "0.1.9",
    "globals": "14.0.0",
    "jiti": "2.6.1",
    "obsidian": "1.8.7",
    "tslib": "2.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "8.35.1"
  }
}
